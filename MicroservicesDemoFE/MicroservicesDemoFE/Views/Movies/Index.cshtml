@{
    ViewData["Title"] = "Movies ABM";
}

<div id="app" class="mt-4">
    <h1>Películas</h1>

    <!-- Botón Crear -->
    <button class="btn btn-primary mb-3" v-on:click="fetchMovies">Peliculas</button>
    <button class="btn btn-primary mb-3" v-on:click="openCreateModal">Nueva Película</button>

    <div v-if="loading" class="position-fixed top-0 start-0 w-100 vh-100 d-flex justify-content-center align-items-center bg-dark bg-opacity-50 text-white">
        <h2>Esperando... {{ loadingSeconds }} seg{{ loadingSeconds > 1 ? 's' : '' }}</h2>
    </div>

    <!-- Tabla de películas -->
    <table class="table table-striped" v-if="movies">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titulo</th>
                <th>Director</th>
                <th>Año</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <tr v-for="movie in movies" :key="movie.id">
                <td>{{ movie.id }}</td>
                <td>{{ movie.title }}</td>
                <td>{{ movie.director }}</td>
                <td>{{ movie.year }}</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" v-on:click="openEditModal(movie)">Editar</button>
                    <button class="btn btn-sm btn-danger" v-on:click="deleteMovie(movie.id)">Eliminar</button>
                </td>
            </tr>
        </tbody>
    </table>

    <!-- Modal Crear/Editar -->
    <div class="modal" tabindex="-1" :class="{ 'show d-block': showModal }">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ editMode ? 'Editar Película' : 'Nueva Película' }}</h5>
                    <button type="button" class="btn-close" v-on:click="closeModal"></button>
                </div>
                <div class="modal-body">
                    <form v-on:submit.prevent="saveMovie">
                        <div class="mb-3">
                            <label class="form-label">Id</label>
                            <input type="text" class="form-control" v-model="currentMovie.id" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Titulo</label>
                            <input type="text" class="form-control" v-model="currentMovie.title" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Director</label>
                            <input type="text" class="form-control" v-model="currentMovie.director" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Año</label>
                            <input type="number" class="form-control" v-model="currentMovie.year" required />
                        </div>
                        <button type="submit" class="btn btn-primary">{{ editMode ? 'Actualizar' : 'Crear' }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/movies.js"></script>
}