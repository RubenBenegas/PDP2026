@{
    ViewData["Title"] = "Reviews ABM";
}

<div id="app" class="mt-4">

    <h1>Reviews</h1>

    <!-- Botón Crear -->
    <button class="btn btn-primary mb-3" v-on:click="fetchReviews">Reviews</button>
    <button class="btn btn-primary mb-3" v-on:click="openCreateModal">Nueva Review</button>
    

    <!-- Overlay de carga -->
    <div v-if="loading" class="position-fixed top-0 start-0 w-100 vh-100 d-flex justify-content-center align-items-center bg-dark bg-opacity-50 text-white">
        <h2>Esperando... {{ loadingSeconds }} seg{{ loadingSeconds > 1 ? 's' : '' }}</h2>
    </div>

    <!-- Tabla de Reviews -->
    <table class="table table-striped" v-if="reviews">
        <thead>
            <tr>
                <th>ID</th>
                <th>Pelicula ID</th>
                <th>Autor</th>
                <th>Rating</th>
                <th>Comentario</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            <tr v-for="review in reviews" :key="review.id">
                <td>{{ review.id }}</td>
                <td>{{ review.movieId }}</td>
                <td>{{ review.reviewer }}</td>
                <td>{{ review.rating }}</td>
                <td>{{ review.comment }}</td>
                <td>
                    <button class="btn btn-sm btn-warning me-1" v-on:click="openEditModal(review)">Editar</button>
                    <button class="btn btn-sm btn-danger" v-on:click="deleteReview(review.id)">Eliminar</button>
                </td>
            </tr>
        </tbody>
    </table>

    <!-- Modal Crear/Editar -->
    <div class="modal" tabindex="-1" :class="{ 'show d-block': showModal }">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">{{ editMode ? 'Editar Review' : 'Nueva Review' }}</h5>
                    <button type="button" class="btn-close" v-on:click="closeModal"></button>
                </div>
                <div class="modal-body">
                    <form v-on:submit.prevent="saveReview">
                        <div class="mb-3">
                            <label class="form-label">ID</label>
                            <input type="text" class="form-control" v-model="currentReview.id" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Movie ID</label>
                            <input type="text" class="form-control" v-model="currentReview.movieId" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reviewer</label>
                            <input type="text" class="form-control" v-model="currentReview.reviewer" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rating</label>
                            <input type="number" class="form-control" v-model="currentReview.rating" min="0" max="10" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Comment</label>
                            <textarea class="form-control" v-model="currentReview.comment" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">{{ editMode ? 'Actualizar' : 'Crear' }}</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/reviews.js"></script>
}